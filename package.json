{
  "name": "nikechan-blog",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/globals.css -o ./public/static/styles/globals.css",
    "watch:css": "tailwindcss -i ./src/styles/globals.css -o ./public/static/styles/globals.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"vite\"",
    "build:server": "npm run build:css && vite build",
    "build:client": "vite build --mode client",
    "fetch-ogp": "bun run scripts/fetch-ogp.ts",
    "generate:sitemap": "bun run scripts/generate-sitemap.ts",
    "check:md-golden": "bun run scripts/md-golden.ts",
    "copy:assets": "bun run scripts/copy-public-assets.ts",
    "build": "npm run fetch-ogp && npm run generate:sitemap && npm run build:css && npm run build:client && vite build && npm run copy:assets",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "video:studio": "remotion studio expo-video/src/index.ts",
    "video:render": "remotion render expo-video/src/index.ts AiGameExpoLoop expo-video/out/ai-game-expo-loop.mp4"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/react-renderer": "^1.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@supabase/supabase-js": "^2.47.10",
    "better-sqlite3": "^11.6.0",
    "chart.js": "^4.4.9",
    "hono": "^4.6.12",
    "honox": "^0.1.40",
    "i18next": "^25.6.0",
    "lucide-react": "^0.536.0",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.5.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@hono/vite-build": "^1.0.0",
    "@hono/vite-dev-server": "^0.16.0",
    "@remotion/captions": "^4.0.453",
    "@remotion/cli": "^4.0.453",
    "@remotion/media": "^4.0.453",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.15",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "remotion": "^4.0.453",
    "tailwindcss": "^3.4.16",
    "vite": "^5.2.12",
    "wrangler": "4.45.4",
    "zod": "^4.3.6"
  }
}
